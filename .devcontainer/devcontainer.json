{
  "name": "Formula SAE Zephyr Workspace",
  
  // Use Zephyr's official Docker image (has everything pre-installed)
  "image": "ghcr.io/zephyrproject-rtos/ci:v0.26.13",
  
  // Mount the workspace into the container
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  
  // Run these commands after container starts
  "postCreateCommand": "west init -l . && west update",
  
  // Keep container running
  "overrideCommand": true,
  
  // Environment variables
  "containerEnv": {
    "ZEPHYR_BASE": "/workspace/zephyr"
  },
  
  // VS Code customizations
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "twxs.cmake",
        "ms-vscode.cmake-tools",
        "marus25.cortex-debug",
        "trond-snekvik.kconfig-lang"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.compilerPath": "/opt/toolchains/zephyr-sdk-0.16.5-1/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc",
        "cmake.configureOnOpen": false
      }
    }
  },
  
  // Forward ports if needed (for debugging, etc.)
  "forwardPorts": []
}